# Copiá este archivo como .env y completá los valores reales.
# IMPORTANTE: restringí la API Key por dominio HTTP en Google Cloud Console
# para evitar uso no autorizado (la key queda expuesta en el bundle del cliente).

VITE_SPREADSHEET_ID=tu_id_de_hoja_aqui
VITE_GOOGLE_API_KEY=tu_api_key_aqui

VITE_FIREBASE_API_KEY=tu_firebase_api_key_aqui
VITE_FIREBASE_AUTH_DOMAIN=tu_proyecto.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=tu_proyecto
VITE_FIREBASE_STORAGE_BUCKET=tu_proyecto.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=tu_sender_id_aqui
VITE_FIREBASE_APP_ID=tu_app_id_aqui
